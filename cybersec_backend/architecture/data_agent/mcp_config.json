{
  "mcp_servers": {
    "collector_executor": {
      "command": "python",
      "args": ["-m", "mcp_servers.collector_executor.server"],
      "transport": "stdio",
      "description": "Execute Phase 1 data collectors on-demand",
      "connection_timeout": 30,
      "request_timeout": 180
    },
    "event_storage": {
      "command": "python",
      "args": ["-m", "mcp_servers.event_storage.server"],
      "transport": "stdio",
      "description": "Persist and query StandardEvent objects"
    },
    "attack_injector": {
      "command": "python",
      "args": ["-m", "mcp_servers.attack_injector.server"],
      "transport": "stdio",
      "description": "Generate realistic attack simulations based on MITRE ATT&CK"
    },
    "enrichment": {
      "command": "python",
      "args": ["-m", "mcp_servers.enrichment.server"],
      "transport": "stdio",
      "description": "Add user/device context and correlate events"
    },
    "python_executor": {
      "command": "python",
      "args": ["-m", "mcp_servers.python_executor.server"],
      "transport": "stdio",
      "description": "Execute Python code in sandboxed environment"
    }
  }
}
